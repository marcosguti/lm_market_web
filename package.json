{
  "name": "lm_market_web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0 <23.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "NODE_OPTIONS=--max-old-space-size=8192 vitest run",
    "test:unit": "NODE_OPTIONS=--max-old-space-size=8192 vitest run --project unit",
    "test:ui": "NODE_OPTIONS=--max-old-space-size=8192 vitest run --project ui",
    "test:bisect": "NODE_OPTIONS=--max-old-space-size=8192 vitest run --reporter=verbose --bail=1",
    "test:watch": "vitest"
  },
  "dependencies": {
